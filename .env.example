# UpGrid environment variables — NAMES ONLY. Never put real values in this file.
# Copy to `.env` for local dev (`.env` is gitignored) or set these in the AWS console.

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# The Lambda Function URL the browser POSTs decisions to. NOT a secret.
# Must be prefixed VITE_ to be exposed to the client bundle.
# Leave unset to run the app in Emulated mode (no backend needed).
VITE_INFERENCE_URL=

# ── Lambda only (server-side — these NEVER reach the browser or the repo) ───────
# Workspace API key for Claude Platform on AWS, sent as the x-api-key header.
ANTHROPIC_AWS_API_KEY=
# Region of the Claude Platform on AWS workspace. Workspace is US East (Ohio).
CLAUDE_AWS_REGION=us-east-2
# Standard AWS region var (read as a fallback if CLAUDE_AWS_REGION is unset).
AWS_REGION=us-east-2
# Workspace id, if the endpoint requires it (short-term keys are usually workspace-scoped).
ANTHROPIC_WORKSPACE_ID=
